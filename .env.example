# EventEase Backend — Environment Variables
# Copy to .env and fill in values. NEVER commit the real .env file.

# Django
DJANGO_SETTINGS_MODULE=eventease.settings.dev
DJANGO_SECRET_KEY=change-me-to-a-random-50-char-string
DJANGO_ALLOWED_HOSTS=localhost,127.0.0.1

# Database
# Leave blank for local dev (uses SQLite automatically).
# On Render, set this to the Internal Database URL from your PostgreSQL instance.
DATABASE_URL=

# Stripe (test mode — report Section 10)
STRIPE_SECRET_KEY=sk_test_REPLACE_ME
STRIPE_WEBHOOK_SECRET=whsec_REPLACE_ME

# Email (SendGrid — report Section 11)
# In dev, the console backend is used regardless of these values.
EMAIL_HOST_PASSWORD=SG.REPLACE_ME
DEFAULT_FROM_EMAIL=noreply@eventease.test

# CORS
CORS_ALLOWED_ORIGINS=http://localhost:3000

# Frontend origin (for links in emails)
FRONTEND_ORIGIN=http://localhost:3000
